# ============================================================
# STORYTUB SERVER - Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================


# ---- Server ----
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ---- Supabase (service_role = full access, bypasses RLS) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
# JWT secret (Settings > API > JWT Secret - used to verify client tokens)
SUPABASE_JWT_SECRET=your-jwt-secret


# ---- Redis (BullMQ job queue) ----
REDIS_URL=redis://127.0.0.1:6379


# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (from Stripe Dashboard > Products)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...
STRIPE_PRICE_BUNDLE_STARTER=price_...
STRIPE_PRICE_BUNDLE_CREATOR=price_...
STRIPE_PRICE_BUNDLE_PRO=price_...
STRIPE_PRICE_BUNDLE_STUDIO=price_...


# ---- AI (OpenAI-compatible: OpenAI, Ollama, etc.) ----
# For Ollama (local): leave OPENAI_API_KEY empty, set OPENAI_BASE_URL to http://127.0.0.1:11434/v1
# For OpenAI: set OPENAI_API_KEY and OPENAI_BASE_URL to https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=mistral


# ---- Image APIs ----
PIXABAY_API_KEY=your-pixabay-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key


# ---- Self-Hosted AI Services (internal VPS URLs) ----
# Kokoro TTS - HTTP wrapper around Kokoro-82M
KOKORO_TTS_URL=http://127.0.0.1:8100
# OpenVoice V2 - voice cloning service
OPENVOICE_URL=http://127.0.0.1:8101
# faster-whisper - word-level timestamp extraction
WHISPER_URL=http://127.0.0.1:8102


# ---- Email (SMTP - use Resend, Postmark, or any SMTP provider) ----
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_...
EMAIL_FROM_NAME=StoryTub
EMAIL_FROM_ADDRESS=noreply@storytub.com
# Admin notification email
ADMIN_EMAIL=admin@storytub.com


# ---- Cloudflare (CDN signed URLs - optional) ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CDN_BASE_URL=https://cdn.storytub.com


# ---- Rate Limiting ----
# Max requests per minute for general API
RATE_LIMIT_MAX=60
# Max guest video generations per IP per day
GUEST_MAX_VIDEOS=1


# ---- Logging ----
# 'fatal','error','warn','info','debug','trace'
LOG_LEVEL=info
